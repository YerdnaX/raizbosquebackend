PORT=3000

# Base de datos SQL Server
DB_USER=tu_usuario_sql
DB_PASSWORD=tu_password_sql
DB_SERVER=tiusr15pl.cuc-carrera-ti.ac.cr
DB_DATABASE=tiusr15pl_RaicesCafeVivero
DB_PORT=1433

# Gmail API (OAuth2) — para envío de correos desde Render
# Ver guía de configuración en el README del proyecto
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_USER=tu_correo@gmail.com

# Timeout para el envío de correo (ms)
EMAIL_TIMEOUT_MS=25000

# =============================================================================
# AUTENTICACIÓN EN DOS FACTORES (2FA)
# =============================================================================
# Clave AES-256-GCM para cifrar los secretos TOTP en la base de datos.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Debe ser exactamente 64 caracteres hexadecimales (32 bytes).
# NUNCA subir el valor real al repositorio.
TWO_FACTOR_ENCRYPTION_KEY=reemplazar_con_64_caracteres_hex
