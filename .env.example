PORT=3000

# Base de datos SQL Server
DB_USER=tu_usuario_sql
DB_PASSWORD=tu_password_sql
DB_SERVER=tiusr15pl.cuc-carrera-ti.ac.cr
DB_DATABASE=tiusr15pl_RaicesCafeVivero
DB_PORT=1433

# Correo electrónico (SMTP) — requerido para envío de códigos de verificación
# Ejemplo con Gmail: habilitar "contraseñas de aplicación" en tu cuenta Google
EMAIL_PROVIDER=auto
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_app_password_de_16_caracteres
EMAIL_FROM=noreply@raicesbosque.com
EMAIL_TIMEOUT_MS=12000
EMAIL_FORCE_IPV4=true
EMAIL_DNS_RESULT_ORDER=ipv4first

# Alternativa recomendada para cloud: API HTTPS de Resend
# Si defines RESEND_API_KEY, EMAIL_PROVIDER=auto usará Resend por defecto.
# También puedes forzar EMAIL_PROVIDER=resend
RESEND_API_KEY=tu_api_key_resend
